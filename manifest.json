{
  "manifest_version": 3,
  "name": "Hermes Brain Clipper",
  "description": "Clip web pages to your Hermes AI agent's brain",
  "version": "1.0.0",
  "permissions": [
    "activeTab",
    "scripting",
    "contextMenus",
    "notifications"
  ],
  "host_permissions": [
    "http://localhost:8642/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+B"
      },
      "description": "Clip current page to brain"
    }
  }
}
